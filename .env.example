# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# ── InvenTree ────────────────────────────────────────────────────────────────
INVENTREE_URL=http://localhost:8000
INVENTREE_USER=admin
INVENTREE_PASS=inventree

# Set to true to run API tests against mock fixtures (no InvenTree needed)
MOCK_MODE=false

# Set to true to regenerate Playwright visual regression baselines
UPDATE_SNAPSHOTS=false

# ── Agentic Orchestrator ─────────────────────────────────────────────────────
# Anthropic API key — required for agents/qa_orchestrator_agent.py
ANTHROPIC_API_KEY=sk-ant-...

# ── Jira Integration (optional) ──────────────────────────────────────────────
# If all three are set, the orchestrator agent auto-creates a Jira bug ticket
# whenever the QA pipeline fails.
#
# JIRA_BASE_URL     Your Jira instance root  e.g. https://jiraeu.epam.com
# JIRA_TOKEN        Personal Access Token (Bearer)
# JIRA_PROJECT_KEY  Target project key       e.g. EPMCDMETST
JIRA_BASE_URL=https://jiraeu.epam.com
JIRA_TOKEN=your-personal-access-token-here
JIRA_PROJECT_KEY=EPMCDMETST
